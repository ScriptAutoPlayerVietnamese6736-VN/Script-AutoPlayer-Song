-- Xóa GUI cũ nếu tồn tại trong CoreGui để tránh lỗi trùng lặp màn hình
local CoreGui = game:GetService("CoreGui")
local ExistingGui = CoreGui:FindFirstChild("MusicSelectorGUI")
if ExistingGui then 
    ExistingGui:Destroy() 
end

-- Khởi tạo ScreenGui gốc nằm trong CoreGui nhằm đảm bảo luôn hiển thị
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "MusicSelectorGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = CoreGui


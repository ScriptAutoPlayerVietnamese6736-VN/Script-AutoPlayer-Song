-- Hàm chạy nhạc không đồng bộ
local function PlayMusicAsync(bpmValue, loaderUrl, songUrl)
    task.spawn(function()
        bpm = bpmValue
        _G.bpm = bpmValue
        
        if loaderUrl and loaderUrl ~= "" then
            pcall(function()
                local code = game:HttpGet(tostring(loaderUrl), true)
                if code and code ~= "" then loadstring(code)() end
            end)
        end
        
        if songUrl and songUrl ~= "" then
            pcall(function()
                local code = game:HttpGet(tostring(songUrl), true)
                if code and code ~= "" then loadstring(code)() end
            end)
        end
    end)
end

----------------------------------------------------------------
-- 1. GIAO DIỆN KHUNG ĐĂNG NHẬP (KEY SYSTEM)
----------------------------------------------------------------
local KeyFrame = Instance.new("Frame")
KeyFrame.Name = "KeyFrame"
KeyFrame.Parent = ScreenGui
KeyFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
KeyFrame.Size = UDim2.new(0, 300, 0, 180)
KeyFrame.Position = UDim2.new(0.5, -150, 0.5, -90)
KeyFrame.ClipsDescendants = true

local KeyCorner = Instance.new("UICorner")
KeyCorner.CornerRadius = UDim.new(0, 10)
KeyCorner.Parent = KeyFrame

local KeyTitle = Instance.new("TextLabel")
KeyTitle.Size = UDim2.new(1, 0, 0, 45)
KeyTitle.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
KeyTitle.Font = Enum.Font.SourceSansBold
KeyTitle.Text = "🔑 ENTER KEY 🔑 "
KeyTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
KeyTitle.TextSize = 16
KeyTitle.Parent = KeyFrame

local KeyInput = Instance.new("TextBox")
KeyInput.Size = UDim2.new(0.8, 0, 0, 35)
KeyInput.Position = UDim2.new(0.1, 0, 0.4, 0)

-- 3. NÚT ẨN/HIỆN (ICON TRÒN CỐ ĐỊNH CẠNH PHẢI MÀN HÌNH)
----------------------------------------------------------------
local HideButton = Instance.new("TextButton")
HideButton.Name = "HideButton"
HideButton.Parent = ScreenGui
HideButton.Size = UDim2.new(0, 45, 0, 45)
HideButton.Position = UDim2.new(1, -55, 0.5, -22)
HideButton.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
HideButton.Font = Enum.Font.SourceSansBold
HideButton.Text = "🎹"
HideButton.TextColor3 = Color3.fromRGB(255, 255, 255)
HideButton.TextSize = 20
HideButton.Visible = false

local HideCorner = Instance.new("UICorner")
HideCorner.CornerRadius = UDim.new(0, 22)
HideCorner.Parent = HideButton

----------------------------------------------------------------
-- XỬ LÝ SỰ KIỆN TƯƠNG TÁC
----------------------------------------------------------------

-- Nhấp nút Xác nhận Key 6767
SubmitBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == "6767" then
        KeyFrame:TweenSizeAndPosition(UDim2.new(0, 0, 0, 0), UDim2.new(0.5, 0, 0.5, 0), Enum.EasingDirection.In, Enum.EasingStyle.Back, 0.3)
        task.wait(0.3)
        KeyFrame:Destroy()
        
        MainFrame.Visible = true
        HideButton.Visible = true
        
        -- Bung mở rộng Menu chính mượt mà
        MainFrame:TweenSize(UDim2.new(0, 380, 0, 470), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.4, true)
    else
        KeyInput.Text = ""
        KeyInput.PlaceholderText = "Sai Key! Vui lòng nhập lại..."
    end
end)

-- Xử lý ẩn/hiện Menu bằng Icon bên phải
local menuVisible = true
HideButton.MouseButton1Click:Connect(function()
    menuVisible = not menuVisible
    if menuVisible then
        MainFrame.Visible = true
        MainFrame:TweenSizeAndPosition(UDim2.new(0, 380, 0, 470), UDim2.new(0.5, -190, 0.5, -235), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
        HideButton.Text = "🎹"
    else
        MainFrame:TweenSizeAndPosition(UDim2.new(0, 380, 0, 0), UDim2.new(0.5, -190, 0.5, -235), Enum.EasingDirection.In, Enum.EasingStyle.Quad, 0.3, true)
        task.wait(0.3)
        MainFrame.Visible = false
        HideButton.Text = "❌"
    end
end)

-- Tạo danh sách các nút chọn bài hát
for index, song in ipairs(Songs) do
    local Button = Instance.new("TextButton")
    local ButtonCorner = Instance.new("UICorner")
    
    Button.Name = "SongButton"
    Button.Parent = ScrollFrame
    Button.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    Button.Size = UDim2.new(1, -6, 0, 40)
    Button.Font = Enum.Font.SourceSansSemibold
    Button.Text = "  " .. song.Name .. " (BPM: " .. tostring(song.BPM) .. ")"
    Button.TextColor3 = Color3.fromRGB(230, 230, 230)
    Button.TextSize = 14
    Button.TextXAlignment = Enum.TextXAlignment.Left 
    
    ButtonCorner.CornerRadius = UDim.new(0, 6)
    ButtonCorner.Parent = Button
    
    Button.MouseEnter:Connect(function()
        Button.BackgroundColor3 = Color3.fromRGB(70, 70, 85)
    end)
    Button.MouseLeave:Connect(function()
        Button.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    end)
    
    Button.MouseButton1Click:Connect(function()
        local originalText = Button.Text
        Button.Text = "  ⏳ Loading piano ⏳: " .. song.Name .. "..."
        Button.BackgroundColor3 = Color3.fromRGB(100, 80, 40)
        
        PlayMusicAsync(song.BPM, song.LoaderUrl, song.SongUrl)
        
        task.wait(1)
        Button.Text = originalText
        Button.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    end)
end
